#!/usr/bin/env python3
import argparse
import json
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
DOMAINS = {"perf", "kernel", "rocm-hip", "llm-e2e", "upstream", "workflow"}
TYPES = {"pattern", "pitfall", "preference", "architecture", "tool", "benchmark", "investigation", "review"}
SOURCES = {"user-stated", "observed", "benchmark", "upstream-doc", "pr-review", "inferred"}


def main() -> int:
    parser = argparse.ArgumentParser(description="Append a raw learning to knowledge/inbox JSONL.")
    parser.add_argument("--domain", required=True, choices=sorted(DOMAINS))
    parser.add_argument("--type", required=True, choices=sorted(TYPES))
    parser.add_argument("--key", required=True)
    parser.add_argument("--insight", required=True)
    parser.add_argument("--source", required=True, choices=sorted(SOURCES))
    parser.add_argument("--confidence", type=int, default=5)
    parser.add_argument("--framework", action="append", default=[])
    parser.add_argument("--hardware", action="append", default=[])
    parser.add_argument("--version", action="append", default=[])
    parser.add_argument("--file", action="append", default=[])
    parser.add_argument("--last-verified")
    args = parser.parse_args()

    if not (1 <= args.confidence <= 10):
        raise SystemExit("--confidence must be 1..10")
    if not all(c.isalnum() or c in "-_" for c in args.key):
        raise SystemExit("--key must contain only letters, numbers, hyphen, or underscore")

    now = datetime.now(timezone.utc)
    record = {
        "ts": now.isoformat().replace("+00:00", "Z"),
        "domain": args.domain,
        "type": args.type,
        "key": args.key,
        "insight": args.insight,
        "source": args.source,
        "confidence": args.confidence,
        "frameworks": args.framework,
        "hardware": args.hardware,
        "versions": args.version,
        "files": args.file,
        "last_verified": args.last_verified or now.date().isoformat(),
        "promotion": "inbox",
    }

    out_dir = ROOT / "knowledge" / "inbox"
    out_dir.mkdir(parents=True, exist_ok=True)
    out_file = out_dir / f"{now.date().isoformat()}.jsonl"
    with out_file.open("a", encoding="utf-8") as f:
        f.write(json.dumps(record, ensure_ascii=True, sort_keys=True) + "\n")
    print(out_file)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
