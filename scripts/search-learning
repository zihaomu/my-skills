#!/usr/bin/env python3
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def main() -> int:
    if len(sys.argv) < 2:
        print("Usage: scripts/search-learning <query>", file=sys.stderr)
        return 2
    tokens = [t.lower() for t in " ".join(sys.argv[1:]).split() if t.strip()]
    paths = sorted((ROOT / "knowledge").glob("**/*.jsonl"))
    hits = []
    for path in paths:
        for line_no, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                continue
            haystack = " ".join(
                str(rec.get(k, "")) for k in ("domain", "type", "key", "insight", "source")
            ).lower()
            if all(tok in haystack for tok in tokens):
                hits.append((path, line_no, rec))
    for path, line_no, rec in hits:
        rel = path.relative_to(ROOT)
        print(f"{rel}:{line_no} [{rec.get('domain')}/{rec.get('type')}] {rec.get('key')}")
        print(f"  {rec.get('insight')}")
    if not hits:
        print("No matches")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

